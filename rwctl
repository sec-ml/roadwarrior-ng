#!/usr/bin/env bash
set -euo pipefail

SWANCTL_DIR="/etc/swanctl"
RW_CONF="${SWANCTL_DIR}/roadwarrior.conf"

[[ $EUID -eq 0 ]] || { echo "ERROR: must run as root (use sudo" >&2; exit 1; }

# load config written by setup.sh
if [[ ! -f "${RW_CONF}" ]]; then
  echo "ERROR: ${RW_CONF} not found - run setup.sh first" >&2; exit 1
fi
. "${RW_CONF}"

if [[ ! -x "$PKI" ]]; then
  echo "ERROR: pki binary not found at ${PKI}" >&2; exit 1
fi

# mobileconfig need unique identifiers
new_uuid() {
  if command -v uuidgen &>/dev/null; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  else
    cat /proc/sys/kernel/random/uuid
  fi
}

# cert may be in x509 (active) or x509suspended (suspended)
client_cert_path() {
  local name="$1"
  if [[ -f "${SWANCTL_DIR}/x509/client_${name}Cert.pem" ]]; then
    echo "${SWANCTL_DIR}/x509/client_${name}Cert.pem"
  elif [[ -f "${SWANCTL_DIR}/x509suspended/client_${name}Cert.pem" ]]; then
    echo "${SWANCTL_DIR}/x509suspended/client_${name}Cert.pem"
  fi
}

# outputs OnDemandRules XML block for the mode/ssids/cellular settings
gen_on_demand_block() {
  local mode="$1"
  local trusted_ssids="$2"
  local cellular="$3"

  [[ "${mode}" == "off" ]] && return
  # \t's to match XML indents
  printf '\t\t\t<key>OnDemandEnabled</key>\n'
  printf '\t\t\t<integer>1</integer>\n'
  printf '\t\t\t<key>OnDemandRules</key>\n'
  printf '\t\t\t<array>\n'

  if [[ -n "${trusted_ssids}" ]]; then
    printf '\t\t\t\t<dict>\n'
    printf '\t\t\t\t\t<key>Action</key>\n'
    printf '\t\t\t\t\t<string>Disconnect</string>\n'
    printf '\t\t\t\t\t<key>SSIDMatch</key>\n'
    printf '\t\t\t\t\t<array>\n'
    IFS=',' read -ra ssids <<< "${trusted_ssids}"
    for ssid in "${ssids[@]}"; do
      ssid="${ssid## }"; ssid="${ssid%% }"
      printf '\t\t\t\t\t\t<string>%s</string>\n' "${ssid}"
    done
    printf '\t\t\t\t\t</array>\n'
    printf '\t\t\t\t</dict>\n'
  fi

  if [[ "${cellular}" == "no" ]]; then
    printf '\t\t\t\t<dict>\n'
    printf '\t\t\t\t\t<key>Action</key>\n'
    printf '\t\t\t\t\t<string>Disconnect</string>\n'
    printf '\t\t\t\t\t<key>InterfaceTypeMatch</key>\n'
    printf '\t\t\t\t\t<string>Cellular</string>\n'
    printf '\t\t\t\t</dict>\n'
  fi

  printf '\t\t\t\t<dict>\n'
  printf '\t\t\t\t\t<key>Action</key>\n'
  printf '\t\t\t\t\t<string>Connect</string>\n'
  printf '\t\t\t\t</dict>\n'
  printf '\t\t\t</array>'
}

# generate mobileconfig for an existing client
# gen_mobileconfig <name> <embed> <client_pass> <on_demand_mode> <trusted_ssids> <cellular>
gen_mobileconfig() {
  local name="$1"
  local embed="${2:-no}"
  local client_pass="${3:-}"
  local on_demand_mode="${4:-${ON_DEMAND_MODE:-off}}"
  local trusted_ssids="${5:-${ON_DEMAND_TRUSTED_SSIDS:-}}"
  local cellular="${6:-${ON_DEMAND_CELLULAR:-yes}}"
  local dist_dir="${SWANCTL_DIR}/dist/${name}"
  local mc_file="${dist_dir}/${name}.mobileconfig"

  if [[ ! -f "${dist_dir}/${name}.p12" ]]; then
    echo "ERROR: missing ${name}.p12 - run 'add' first" >&2; exit 1
  fi
  if [[ ! -f "${SWANCTL_DIR}/x509ca/caCert.der" ]]; then
    echo "ERROR: missing caCert.der - run setup.sh first" >&2; exit 1
  fi

  local uuid_pkcs12 uuid_vpnconfig uuid_cacert uuid_id uuid_top
  uuid_pkcs12=$(new_uuid);  uuid_vpnconfig=$(new_uuid)
  uuid_cacert=$(new_uuid);  uuid_id=$(new_uuid);  uuid_top=$(new_uuid)

  cat > "${mc_file}" <<MOBILECONFIG
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>PayloadContent</key>
	<array>
		<dict>
			<key>IKEv2</key>
			<dict>
				<key>AuthenticationMethod</key>
				<string>Certificate</string>
				<key>ChildSecurityAssociationParameters</key>
				<dict>
					<key>DiffieHellmanGroup</key>
					<integer>20</integer>
					<key>EncryptionAlgorithm</key>
					<string>AES-256</string>
					<key>IntegrityAlgorithm</key>
					<string>SHA2-256</string>
					<key>LifeTimeInMinutes</key>
					<integer>1440</integer>
				</dict>
				<key>DeadPeerDetectionRate</key>
				<string>Low</string>
				<key>DisableMOBIKE</key>
				<integer>0</integer>
				<key>DisableRedirect</key>
				<integer>0</integer>
				<key>EnableCertificateRevocationCheck</key>
				<integer>0</integer>
				<key>EnablePFS</key>
				<true/>
				<key>IKESecurityAssociationParameters</key>
				<dict>
					<key>DiffieHellmanGroup</key>
					<integer>20</integer>
					<key>EncryptionAlgorithm</key>
					<string>AES-256</string>
					<key>IntegrityAlgorithm</key>
					<string>SHA2-256</string>
					<key>LifeTimeInMinutes</key>
					<integer>1440</integer>
				</dict>
				<!-- 0 = cert-only auth. Without this, iOS prompts for EAP creds -->
				<key>ExtendedAuthEnabled</key>
				<integer>0</integer>
				<key>LocalIdentifier</key>
				<string>${name}@${VPN_NAME}</string>
				<key>PayloadCertificateUUID</key>
				<string>${uuid_pkcs12}</string>
				<key>RemoteAddress</key>
				<string>${VPN_NAME}</string>
				<key>RemoteIdentifier</key>
				<string>${VPN_NAME}</string>
				<!-- ServerCertificateCommonName & ServerCertificateIssuerCommonName both required. iOS seems to disconnect immediately if either is missing -->
				<key>ServerCertificateCommonName</key>
				<string>${VPN_NAME}</string>
				<key>ServerCertificateIssuerCommonName</key>
				<string>${VPN_NAME} CA</string>
				<key>UseConfigurationAttributeInternalIPSubnet</key>
				<integer>0</integer>
			</dict>
			<key>IPv4</key>
			<dict>
				<!-- 0 = iOS routes based on server-negotiated traffic selectors (local_ts). 1 would force full tunnel client-side -->
				<key>OverridePrimary</key>
				<integer>0</integer>
			</dict>
			%%ON_DEMAND%%
			<key>PayloadDescription</key>
			<string>Configures VPN settings</string>
			<key>PayloadDisplayName</key>
			<string>VPN</string>
			<key>PayloadIdentifier</key>
			<string>com.apple.vpn.managed.${uuid_vpnconfig}</string>
			<key>PayloadType</key>
			<string>com.apple.vpn.managed</string>
			<key>PayloadUUID</key>
			<string>${uuid_vpnconfig}</string>
			<key>PayloadVersion</key>
			<real>1</real>
			<key>Proxies</key>
			<dict>
				<key>HTTPEnable</key>
				<integer>0</integer>
				<key>HTTPSEnable</key>
				<integer>0</integer>
			</dict>
			<key>UserDefinedName</key>
			<string>${VPN_NAME}</string>
			<key>VPNType</key>
			<string>IKEv2</string>
		</dict>
		<dict>
			<key>PayloadCertificateFileName</key>
			<string>${VPN_NAME}_ca.der</string>
			<key>PayloadContent</key>
			<data>
			%%CERT_CA_DER%%
			</data>
			<key>PayloadDescription</key>
			<string>Adds a CA root certificate</string>
			<key>PayloadDisplayName</key>
			<string>${VPN_NAME} CA</string>
			<key>PayloadIdentifier</key>
			<string>com.apple.security.root.${uuid_cacert}</string>
			<key>PayloadType</key>
			<string>com.apple.security.root</string>
			<key>PayloadUUID</key>
			<string>${uuid_cacert}</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
		</dict>
		<dict>
			%%PASSWORD%%
			<key>PayloadCertificateFileName</key>
			<string>${name}.p12</string>
			<key>PayloadContent</key>
			<data>
			%%CERT_PKCS12%%
			</data>
			<key>PayloadDescription</key>
			<string>Adds a PKCS#12-formatted certificate</string>
			<key>PayloadDisplayName</key>
			<string>${name}.p12</string>
			<key>PayloadIdentifier</key>
			<string>com.apple.security.pkcs12.${uuid_pkcs12}</string>
			<key>PayloadType</key>
			<string>com.apple.security.pkcs12</string>
			<key>PayloadUUID</key>
			<string>${uuid_pkcs12}</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
		</dict>
	</array>
	<key>PayloadDescription</key>
	<string>Mobile device VPN package</string>
	<key>PayloadDisplayName</key>
	<string>${VPN_NAME}</string>
	<key>PayloadIdentifier</key>
	<string>${uuid_id}</string>
	<key>PayloadOrganization</key>
	<string>${VPN_NAME}</string>
	<key>PayloadRemovalDisallowed</key>
	<false/>
	<key>PayloadType</key>
	<string>Configuration</string>
	<key>PayloadUUID</key>
	<string>${uuid_top}</string>
	<key>PayloadVersion</key>
	<integer>1</integer>
</dict>
</plist>
MOBILECONFIG

  # %%CERT_CA_DER%%, %%CERT_PKCS12%%, %%PASSWORD%% are substituted below via awk/sed (can't inline because of base64 output)
  # %%ON_DEMAND%% substituted because...multiline indented block reasons.

  # embed or remove OnDemand block
  local tmp; tmp=$(mktemp)
  local on_demand_block; on_demand_block=$(gen_on_demand_block "${on_demand_mode}" "${trusted_ssids}" "${cellular}")
  if [[ -n "${on_demand_block}" ]]; then
    local tmp_od; tmp_od=$(mktemp)
    printf '%s\n' "${on_demand_block}" > "${tmp_od}"
    awk "/%%ON_DEMAND%%/ { while ((getline line < \"${tmp_od}\") > 0) print line; next } { print }" \
      "${mc_file}" > "$tmp" && mv "$tmp" "${mc_file}"
    rm -f "${tmp_od}"
  else
    sed "/%%ON_DEMAND%%/d" "${mc_file}" > "$tmp" && mv "$tmp" "${mc_file}"
  fi

  # embed or remove the password block
  local tmp; tmp=$(mktemp)
  if [[ "${embed}" == "yes" ]]; then
    sed "s|%%PASSWORD%%|<key>Password</key><string>${client_pass}</string>|" \
      "${mc_file}" > "$tmp" && mv "$tmp" "${mc_file}"
  else
    sed "/%%PASSWORD%%/d" "${mc_file}" > "$tmp" && mv "$tmp" "${mc_file}"
  fi

  # embed CA cert DER (base64)
  tmp=$(mktemp)
  awk "/%%CERT_CA_DER%%/ { system(\"base64 ${SWANCTL_DIR}/x509ca/caCert.der\") } \
       !/%%CERT_CA_DER%%/ { print }" \
    "${mc_file}" > "$tmp" && mv "$tmp" "${mc_file}"

  # embed PKCS12 (base64)
  tmp=$(mktemp)
  awk "/%%CERT_PKCS12%%/ { system(\"base64 ${dist_dir}/${name}.p12\") } \
       !/%%CERT_PKCS12%%/ { print }" \
    "${mc_file}" > "$tmp" && mv "$tmp" "${mc_file}"

  chmod 600 "${mc_file}"
}

cmd_add() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "usage: rwctl add <name> [--password <pass>] [--embed-password] [--on-demand off|always|untrusted] [--trusted-ssids <ssids>] [--cellular yes|no] [--routing full|split]" >&2; exit 1
  fi
  shift

  local embed="no"
  local custom_pass=""
  local on_demand="${ON_DEMAND_MODE:-off}"
  local trusted_ssids="${ON_DEMAND_TRUSTED_SSIDS:-}"
  local cellular="${ON_DEMAND_CELLULAR:-yes}"
  local routing="full"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --embed-password) embed="yes" ;;
      --password) custom_pass="${2:-}"; shift ;;
      --on-demand) on_demand="${2:-}"; shift ;;
      --trusted-ssids) trusted_ssids="${2:-}"; shift ;;
      --cellular) cellular="${2:-}"; shift ;;
      --routing) routing="${2:-}"; shift ;;
      *) echo "ERROR: unknown option $1" >&2; exit 1 ;;
    esac
    shift
  done

  if [[ -f "${SWANCTL_DIR}/private/client_${name}Key.pem" ]]; then
    echo "ERROR: client '${name}' already exists - use 'regen' to rebuild the mobileconfig" >&2; exit 1
  fi

  local dist_dir="${SWANCTL_DIR}/dist/${name}"
  mkdir -p "${dist_dir}"
  chmod 700 "${dist_dir}"

  # pw priority: --password flag > server default > random
  local client_pass
  if [[ -n "${custom_pass}" ]]; then
    client_pass="${custom_pass}"
  elif [[ -n "${CERT_PASSWORD:-}" ]]; then
    client_pass="${CERT_PASSWORD}"
  else
    client_pass=$(openssl rand -base64 16 | tr -d '/+=')
  fi
  echo "creating client: ${name}@${VPN_NAME}"

  # client key
  "$PKI" --gen --type rsa --size 2048 --outform pem \
    > "${SWANCTL_DIR}/private/client_${name}Key.pem"
  chmod 600 "${SWANCTL_DIR}/private/client_${name}Key.pem"

  # client cert - SAN must match LocalIdentifier in mobileconfig
  "$PKI" --pub --in "${SWANCTL_DIR}/private/client_${name}Key.pem" --type rsa \
    | "$PKI" --issue \
        --cacert  "${SWANCTL_DIR}/x509ca/caCert.pem" \
        --cakey   "${SWANCTL_DIR}/private/caKey.pem" \
        --dn      "C=NZ, O=roadwarrior, CN=${name}@${VPN_NAME}" \
        --san     "${name}@${VPN_NAME}" \
        --lifetime "${CERT_LIFESPAN}" \
        --digest  sha256 \
        --outform pem \
    > "${SWANCTL_DIR}/x509/client_${name}Cert.pem"

  # PKCS12 - -legacy required for Apple/OpenSSL 3.x compatibility (affects .p12 password encryption, not VPN encryption)
  openssl pkcs12 -legacy -export \
    -inkey    "${SWANCTL_DIR}/private/client_${name}Key.pem" \
    -in       "${SWANCTL_DIR}/x509/client_${name}Cert.pem" \
    -certfile "${SWANCTL_DIR}/x509ca/caCert.pem" \
    -caname   "${VPN_NAME} CA" \
    -name     "${name}" \
    -password "pass:${client_pass}" \
    -out      "${dist_dir}/${name}.p12"

  cp "${SWANCTL_DIR}/x509/client_${name}Cert.pem" "${dist_dir}/${name}Cert.pem"
  cp "${SWANCTL_DIR}/private/client_${name}Key.pem" "${dist_dir}/${name}Key.pem"
  cp "${SWANCTL_DIR}/x509ca/caCert.pem" "${dist_dir}/CACert.pem"
  cp "${SWANCTL_DIR}/x509ca/caCert.der" "${dist_dir}/CACert.der"

  gen_mobileconfig "${name}" "${embed}" "${client_pass}" "${on_demand}" "${trusted_ssids}" "${cellular}"

  apply_routing "${name}" "${routing}"
  swanctl --load-all

  echo ""
  echo "client '${name}' created"
  echo "mobileconfig : ${dist_dir}/${name}.mobileconfig"
  echo "PKCS12       : ${dist_dir}/${name}.p12"
  if [[ "${embed}" == "yes" ]]; then
    echo "password     : embedded in mobileconfig"
  else
    echo "password     : ${client_pass}  (send separately)"
  fi
  echo "identity     : ${name}@${VPN_NAME}"
}

cmd_regen() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "usage: rwctl regen <name> [--password <pass>] [--embed-password] [--on-demand off|always|untrusted] [--trusted-ssids <ssids>] [--cellular yes|no] [--routing full|split]" >&2; exit 1
  fi
  shift

  local embed="no"
  local custom_pass=""
  local on_demand="${ON_DEMAND_MODE:-off}"
  local trusted_ssids="${ON_DEMAND_TRUSTED_SSIDS:-}"
  local cellular="${ON_DEMAND_CELLULAR:-yes}"
  local routing=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --embed-password) embed="yes" ;;
      --password) custom_pass="${2:-}"; shift ;;
      --on-demand) on_demand="${2:-}"; shift ;;
      --trusted-ssids) trusted_ssids="${2:-}"; shift ;;
      --cellular) cellular="${2:-}"; shift ;;
      --routing) routing="${2:-}"; shift ;;
      *) echo "ERROR: unknown option $1" >&2; exit 1 ;;
    esac
    shift
  done

  local dist_dir="${SWANCTL_DIR}/dist/${name}"

  if [[ ! -f "${SWANCTL_DIR}/private/client_${name}Key.pem" ]]; then
    echo "ERROR: client '${name}' not found" >&2; exit 1
  fi
  if [[ ! -f "${dist_dir}/${name}.p12" ]]; then
    echo "ERROR: ${name}.p12 missing - client data may be incomplete" >&2; exit 1
  fi

  local client_pass
  if [[ -n "${custom_pass}" ]]; then
    client_pass="${custom_pass}"
  elif [[ -n "${CERT_PASSWORD:-}" ]]; then
    client_pass="${CERT_PASSWORD}"
  else
    client_pass=$(openssl rand -base64 16 | tr -d '/+=')
  fi

  if [[ -n "${custom_pass}" ]]; then
    local cert_path; cert_path=$(client_cert_path "${name}")
    # PKCS12 - -legacy required for Apple/OpenSSL 3.x compatibility (affects .p12 password encryption, not VPN encryption)
    openssl pkcs12 -legacy -export \
      -inkey    "${SWANCTL_DIR}/private/client_${name}Key.pem" \
      -in       "${cert_path}" \
      -certfile "${SWANCTL_DIR}/x509ca/caCert.pem" \
      -caname   "${VPN_NAME} CA" \
      -name     "${name}" \
      -password "pass:${client_pass}" \
      -out      "${dist_dir}/${name}.p12"
  fi

  echo "regenerating mobileconfig for: ${name}"
  gen_mobileconfig "${name}" "${embed}" "${client_pass}" "${on_demand}" "${trusted_ssids}" "${cellular}"

  if [[ -n "${routing}" ]]; then
    apply_routing "${name}" "${routing}"
    swanctl --load-all --clear
  fi
  echo "done: ${SWANCTL_DIR}/dist/${name}/${name}.mobileconfig"
}

cmd_revoke() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "usage: rwctl revoke <name>" >&2; exit 1
  fi

  if [[ ! -f "${SWANCTL_DIR}/private/client_${name}Key.pem" ]]; then
    echo "ERROR: client '${name}' not found" >&2; exit 1
  fi

  read -r -p "remove all files for client '${name}'? [y/N] " confirm
  if [[ "${confirm,,}" != "y" ]]; then
    echo "aborted"; exit 0
  fi

  # specifically terminate session. Previous method didn't stop active connections.
  swanctl --terminate --ike "rw-${name}" 2>/dev/null || true

  rm -f "${SWANCTL_DIR}/private/client_${name}Key.pem"
  rm -f "${SWANCTL_DIR}/x509/client_${name}Cert.pem"
  rm -f "${SWANCTL_DIR}/x509suspended/client_${name}Cert.pem"
  rm -f "${SWANCTL_DIR}/conf.d/client-${name}.conf"
  rm -f "${SWANCTL_DIR}/conf.d/client-${name}.conf.suspended"
  rm -f "${SWANCTL_DIR}/conf.d/routing-${name}.conf"
  rm -rf "${SWANCTL_DIR}/dist/${name}"

  # reload configs. Existing connections shouldn't be affected...
  swanctl --load-all
  echo "client '${name}' removed"
}

cmd_list() {
  echo "clients:"
  local found=0
  for cert in "${SWANCTL_DIR}"/x509/client_*Cert.pem \
              "${SWANCTL_DIR}"/x509suspended/client_*Cert.pem; do
    [[ -f "$cert" ]] || continue
    local fname; fname=$(basename "$cert")
    local name="${fname#client_}"; name="${name%Cert.pem}"
    local expiry; expiry=$(openssl x509 -in "$cert" -noout -enddate 2>/dev/null | cut -d= -f2)
    if [[ "$cert" == *x509suspended* ]]; then
      printf "  %-20s  expires: %s  [suspended]\n" "${name}" "${expiry}"
    else
      printf "  %-20s  expires: %s\n" "${name}" "${expiry}"
    fi
    found=1
  done
  [[ $found -eq 1 ]] || echo "(none)"
}

cmd_status() {
  swanctl --list-sas
}

cmd_start()   { systemctl start strongswan;   echo "strongswan started"; }
cmd_stop()    { systemctl stop strongswan;    echo "strongswan stopped"; }
cmd_restart() { systemctl restart strongswan; echo "strongswan restarted"; }
cmd_reboot()  { echo "rebooting..."; systemctl reboot; }

# write per-client connection config
# apply_routing <name> <full|split>
apply_routing() {
  local name="$1"
  local mode="$2"
  local conn_conf="${SWANCTL_DIR}/conf.d/client-${name}.conf"
  local local_ts

  if [[ "${mode}" == "split" ]]; then
    if [[ -z "${VPN_SPLIT_SUBNETS:-}" ]]; then
      echo "ERROR: VPN_SPLIT_SUBNETS not set - run setup.sh with split subnets first" >&2; exit 1
    fi
    local_ts="${VPN_SPLIT_SUBNETS}"
  else
    local_ts="0.0.0.0/0"
  fi

  cat > "${conn_conf}" <<CONN
connections {
  rw-${name} {
    version = 2
    local_addrs = 0.0.0.0
    proposals = aes256-sha256-ecp384, aes256-sha256-modp2048, aes128-sha1-modp2048
    pools = rw_pool
    local {
      auth = pubkey
      certs = serverCert.pem
      id = ${VPN_NAME}
    }
    remote {
      auth = pubkey
      id   = "${name}@${VPN_NAME}"
    }
    children {
      rw {
        local_ts = ${local_ts}
        esp_proposals = aes256-sha256-ecp384, aes256-sha256-modp2048, aes128-sha1-modp2048
        dpd_action = clear
        start_action = trap
        updown = ${SWANCTL_DIR}/updown.sh
      }
    }
  }
}
CONN
}

cmd_suspend() {
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "usage: rwctl suspend <name>" >&2; exit 1; }
  [[ -f "${SWANCTL_DIR}/private/client_${name}Key.pem" ]] \
    || { echo "ERROR: client '${name}' not found" >&2; exit 1; }
  [[ -f "${SWANCTL_DIR}/x509/client_${name}Cert.pem" ]] \
    || { echo "client '${name}' is already suspended"; exit 0; }

  # specifically terminate session. Previous method didn't stop active connections.
  swanctl --terminate --ike "rw-${name}" 2>/dev/null || true

  mkdir -p "${SWANCTL_DIR}/x509suspended"
  mv "${SWANCTL_DIR}/x509/client_${name}Cert.pem" \
     "${SWANCTL_DIR}/x509suspended/client_${name}Cert.pem"

  local conn_conf="${SWANCTL_DIR}/conf.d/client-${name}.conf"
  [[ -f "${conn_conf}" ]] && mv "${conn_conf}" "${conn_conf}.suspended"

  # reload connections
  swanctl --load-conns
  echo "client '${name}' suspended"
}

cmd_unsuspend() {
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "usage: rwctl unsuspend <name>" >&2; exit 1; }
  [[ -f "${SWANCTL_DIR}/private/client_${name}Key.pem" ]] \
    || { echo "ERROR: client '${name}' not found" >&2; exit 1; }
  [[ -f "${SWANCTL_DIR}/x509suspended/client_${name}Cert.pem" ]] \
    || { echo "client '${name}' is not suspended"; exit 0; }

  mv "${SWANCTL_DIR}/x509suspended/client_${name}Cert.pem" \
     "${SWANCTL_DIR}/x509/client_${name}Cert.pem"

  local conn_conf="${SWANCTL_DIR}/conf.d/client-${name}.conf"
  [[ -f "${conn_conf}.suspended" ]] && mv "${conn_conf}.suspended" "${conn_conf}"

  swanctl --load-conns
  echo "client '${name}' unsuspended"
}

cmd_set_routing() {
  local name="${1:-}"
  local mode="${2:-}"
  if [[ -z "$name" || -z "$mode" ]]; then
    echo "usage: rwctl set-routing <name> full|split" >&2; exit 1
  fi
  if [[ "${mode}" != "full" && "${mode}" != "split" ]]; then
    echo "ERROR: mode must be full or split" >&2; exit 1
  fi
  if [[ ! -f "${SWANCTL_DIR}/private/client_${name}Key.pem" ]]; then
    echo "ERROR: client '${name}' not found" >&2; exit 1
  fi

  apply_routing "${name}" "${mode}"
  swanctl --load-conns --clear
  echo "${name}: routing set to ${mode}"
}

cmd_serve() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "usage: rwctl serve <name> [--port <port>]" >&2; exit 1
  fi
  shift

  local port=8000
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) port="${2:-}"; shift ;;
      *) echo "ERROR: unknown option $1" >&2; exit 1 ;;
    esac
    shift
  done

  local dist_dir="${SWANCTL_DIR}/dist/${name}"
  if [[ ! -d "${dist_dir}" ]]; then
    echo "ERROR: client '${name}' not found" >&2; exit 1
  fi

  echo "serving ${dist_dir} on port ${port} for 60 seconds"
  echo "url: http://$(hostname -f):${port}/"
  echo "press ctrl-c to stop early"
  echo ""

  # start python http server in bg, kill after 60s
  python3 -m http.server "${port}" --directory "${dist_dir}" &
  local server_pid=$!
  ( sleep 60; kill "${server_pid}" 2>/dev/null ) &
  wait "${server_pid}" 2>/dev/null || true
  echo "server stopped"
}

# add or replace a key=value line in roadwarrior.conf
set_conf_var() {
  local key="$1" val="$2"
  if grep -q "^${key}=" "${RW_CONF}"; then
    sed -i "s|^${key}=.*|${key}=\"${val}\"|" "${RW_CONF}"
  else
    echo "${key}=\"${val}\"" >> "${RW_CONF}"
  fi
}

cmd_mqtt_config() {
  local host port user pass client_id prefix ha_prefix mm_key mm_db
  host="${MQTT_HOST:-}"
  port="${MQTT_PORT:-1883}"
  user="${MQTT_USER:-}"
  pass="${MQTT_PASS:-}"
  client_id="${MQTT_CLIENT_ID:-roadwarrior}"
  prefix="${MQTT_PREFIX:-roadwarrior}"
  ha_prefix="${HA_PREFIX:-homeassistant}"
  mm_key="${MAXMIND_LICENSE_KEY:-}"
  mm_db="${MAXMIND_DB_PATH:-/var/lib/GeoIP}"

  read -r -p "MQTT host [${host:-none}]: " input;          [[ -n "$input" ]] && host="$input"
  read -r -p "MQTT port [${port}]: " input;                [[ -n "$input" ]] && port="$input"
  read -r -p "MQTT user [${user:-none}]: " input;          [[ -n "$input" ]] && user="$input"
  read -r -s -p "MQTT password (enter to keep): " input;   echo; [[ -n "$input" ]] && pass="$input"
  read -r -p "MQTT client ID [${client_id}]: " input;      [[ -n "$input" ]] && client_id="$input"
  read -r -p "Topic prefix [${prefix}]: " input;           [[ -n "$input" ]] && prefix="$input"
  read -r -p "HA discovery prefix [${ha_prefix}]: " input; [[ -n "$input" ]] && ha_prefix="$input"
  read -r -p "MaxMind license key [${mm_key:+set}]: " input; [[ -n "$input" ]] && mm_key="$input"
  read -r -p "MaxMind DB path [${mm_db}]: " input;         [[ -n "$input" ]] && mm_db="$input"

  [[ -n "$host" ]] || { echo "ERROR: MQTT host is required" >&2; exit 1; }

  set_conf_var MQTT_HOST           "${host}"
  set_conf_var MQTT_PORT           "${port}"
  set_conf_var MQTT_USER           "${user}"
  set_conf_var MQTT_PASS           "${pass}"
  set_conf_var MQTT_CLIENT_ID      "${client_id}"
  set_conf_var MQTT_PREFIX         "${prefix}"
  set_conf_var HA_PREFIX           "${ha_prefix}"
  set_conf_var MAXMIND_LICENSE_KEY "${mm_key}"
  set_conf_var MAXMIND_DB_PATH     "${mm_db}"

  if [[ -n "${mm_key}" ]]; then
    echo "downloading MaxMind GeoLite2 databases..."
    mkdir -p "${mm_db}"
    for edition in GeoLite2-City GeoLite2-ASN; do
      local url="https://download.maxmind.com/app/geoip_download?edition_id=${edition}&license_key=${mm_key}&suffix=tar.gz"
      local tmp; tmp=$(mktemp /tmp/maxmind-XXXXXX.tar.gz)
      curl -fsSL "${url}" -o "${tmp}"
      tar -xzf "${tmp}" --strip-components=1 -C "${mm_db}" --wildcards '*.mmdb'
      rm -f "${tmp}"
      echo "  ${edition}.mmdb installed to ${mm_db}"
    done
  fi

  if systemctl is-active roadwarrior-mqtt &>/dev/null; then
    systemctl restart roadwarrior-mqtt
    echo "mqtt daemon restarted"
  fi
  echo "done"
}

cmd_mqtt() {
  local subcmd="${1:-}"
  case "${subcmd}" in
    config)  cmd_mqtt_config ;;
    status)  systemctl status roadwarrior-mqtt --no-pager ;;
    start)   systemctl start roadwarrior-mqtt;   echo "mqtt daemon started" ;;
    stop)    systemctl stop roadwarrior-mqtt;    echo "mqtt daemon stopped" ;;
    restart) systemctl restart roadwarrior-mqtt; echo "mqtt daemon restarted" ;;
    *) echo "usage: rwctl mqtt config|status|start|stop|restart" >&2; exit 1 ;;
  esac
}

case "${1:-}" in
  add)    shift; cmd_add    "$@" ;;
  regen)  shift; cmd_regen  "$@" ;;
  revoke) shift; cmd_revoke "$@" ;;
  serve)  shift; cmd_serve  "$@" ;;
  suspend)     shift; cmd_suspend   "$@" ;;
  unsuspend)   shift; cmd_unsuspend "$@" ;;
  set-routing) shift; cmd_set_routing "$@" ;;
  list)         cmd_list ;;
  status)       cmd_status ;;
  start)        cmd_start ;;
  stop)         cmd_stop ;;
  restart)      cmd_restart ;;
  reboot)       cmd_reboot ;;
  mqtt)   shift; cmd_mqtt "$@" ;;
  *)
    echo "usage: rwctl <command> [args]"
    echo ""
    echo "add    <name> [--password <pass>] [--embed-password] [--on-demand off|always|untrusted] [--trusted-ssids <ssids>] [--cellular yes|no] [--routing full|split]"
    echo "regen  <name> [--password <pass>] [--embed-password] [--on-demand off|always|untrusted] [--trusted-ssids <ssids>] [--cellular yes|no] [--routing full|split]"
    echo "revoke <name>"
    echo "serve  <name> [--port <port>]"
    echo "suspend   <name>"
    echo "unsuspend <name>"
    echo "set-routing <name> full|split"
    echo "list"
    echo "status"
    echo "start | stop | restart"
    echo "reboot"
    echo "mqtt  config|status|start|stop|restart"
    exit 1
    ;;
esac
